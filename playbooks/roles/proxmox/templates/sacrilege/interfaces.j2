auto lo
iface lo inet loopback
iface enp0s31f6 inet manual
iface wlp5s0 inet manual

auto vmbr0
iface vmbr0 inet manual
	bridge-ports enp0s31f6
	bridge-stp off
	bridge-fd 0
	bridge-vlan-aware yes
	bridge-vids 2-4094

auto vmbr0.{{ networking.hypervisor.vid }}
iface vmbr0.{{ networking.hypervisor.vid }} inet static
	address {{ networking.hypervisor.hosts[inventory_hostname_short] }}
	gateway {{ networking.hypervisor.hosts[inventory_hostname_short] | ansible.utils.ipaddr('last_usable') }}
	dns-nameservers {{ services.dns }}
	dns-search {{ tld.internal }}

source /etc/network/interfaces.d/*
